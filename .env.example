# Supabase project the app connects to.
# Find these values in: Supabase Dashboard → Project Settings → API
#   - URL is "Project URL"
#   - Anon key is "anon public" (NOT the service_role key)
#
# Both are required. Copy this file to `.env.local` and fill in the values,
# or set them as environment variables in your hosting provider.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
